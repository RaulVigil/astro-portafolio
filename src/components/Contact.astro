---
---

<section class="py-stack-lg border-t border-border-subtle/50 animate-on-scroll" id="contacto">
<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
<div>
<h2 class="text-headline-lg-mobile md:text-headline-lg font-headline-lg-mobile md:font-headline-lg text-text-primary mb-4">Iniciemos un <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">nuevo proyecto</span></h2>
<p class="text-body-lg font-body-lg text-on-surface-variant mb-8">
                        ¿Tienes un requerimiento técnico complejo o necesitas escalar tu infraestructura web actual? Envíame un mensaje y evaluemos cómo puedo aportar valor a tu equipo o proyecto.
                    </p>
<div class="space-y-4">
<div class="flex items-center gap-4 text-text-secondary">
<span class="material-symbols-outlined text-primary">location_on</span>
<span class="font-label-md text-label-md">Remoto / Disponible Globalmente</span>
</div>
<div class="flex items-center gap-4 text-text-secondary">
<span class="material-symbols-outlined text-primary">mail</span>
<span class="font-label-md text-label-md">rauleduardovigil@gmail.com</span>
</div>
</div>
</div>
<div class="glass-panel p-8 rounded-xl">
<form id="contact-form" class="space-y-6">
<div>
<label class="block text-label-md font-label-md text-text-secondary mb-2" for="name">Nombre Completo</label>
<input class="w-full input-glass rounded p-3 text-body-md font-body-md" id="name" name="name" placeholder="Ej. Jane Doe" type="text" required/>
</div>
<div>
<label class="block text-label-md font-label-md text-text-secondary mb-2" for="email">Correo Electrónico</label>
<input class="w-full input-glass rounded p-3 text-body-md font-body-md" id="email" name="email" placeholder="jane@ejemplo.com" type="email" required/>
</div>
<div>
<label class="block text-label-md font-label-md text-text-secondary mb-2" for="project-type">Tipo de Proyecto</label>
<select class="w-full input-glass rounded p-3 text-body-md font-body-md appearance-none" id="project-type" name="project-type" required>
<option class="text-surface-variant" disabled selected value="">Selecciona una opción</option>
<option class="bg-surface" value="custom">Desarrollo a Medida</option>
<option class="bg-surface" value="ecommerce">E-commerce / Web</option>
<option class="bg-surface" value="maintenance">Mantenimiento / Optimización</option>
<option class="bg-surface" value="consulting">Consultoría Técnica</option>
</select>
</div>
<div>
<label class="block text-label-md font-label-md text-text-secondary mb-2" for="message">Mensaje / Detalles del Proyecto</label>
<textarea class="w-full input-glass rounded p-3 text-body-md font-body-md resize-none" id="message" name="message" placeholder="Describe brevemente los requerimientos..." rows="4" required></textarea>
</div>
<button class="w-full btn-primary py-4 rounded font-label-md text-label-md font-bold flex justify-center items-center gap-2" type="submit">
<span class="material-symbols-outlined">send</span> Enviar Mensaje
                        </button>
</form>
<div id="form-message" class="hidden text-center mt-4 font-label-md p-3 rounded"></div>
</div>
</div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const messageDiv = document.getElementById('form-message') as HTMLDivElement;
  const submitButton = form?.querySelector('button[type="submit"]') as HTMLButtonElement;
  
  if (form && submitButton && messageDiv) {
    const buttonText = submitButton.innerHTML;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Reset state
      messageDiv.className = 'hidden text-center mt-4 font-label-md p-3 rounded';
      messageDiv.textContent = '';
      submitButton.disabled = true;
      submitButton.innerHTML = '<span class="material-symbols-outlined animate-spin">refresh</span> Enviando...';
      submitButton.classList.add('opacity-70', 'cursor-not-allowed');
      
      try {
        const formData = new FormData(form);
        const res = await fetch('/api/send', {
          method: 'POST',
          body: formData
        });
        
        const data = await res.json();
        
        if (res.ok && data.success) {
          messageDiv.textContent = '¡Mensaje enviado con éxito! Te responderé pronto.';
          messageDiv.classList.add('bg-green-500/20', 'text-green-400', 'border', 'border-green-500/30', 'block');
          messageDiv.classList.remove('hidden');
          form.reset();
        } else {
          throw new Error(data.error || 'Ocurrió un error al enviar el mensaje.');
        }
      } catch (error: any) {
        messageDiv.textContent = error.message;
        messageDiv.classList.add('bg-red-500/20', 'text-red-400', 'border', 'border-red-500/30', 'block');
        messageDiv.classList.remove('hidden');
      } finally {
        submitButton.disabled = false;
        submitButton.innerHTML = buttonText;
        submitButton.classList.remove('opacity-70', 'cursor-not-allowed');
      }
    });
  }
</script>
