---
const currentYear = new Date().getFullYear();
---

<footer class="bg-surface-container-lowest border-t border-white/5 py-[64px] md:py-[120px]">
  <div class="max-w-[1200px] mx-auto px-[24px] flex flex-col md:flex-row justify-between items-center gap-8">
    <span class="font-headline-md text-headline-md font-bold text-on-surface">Raúl Vigil</span>
    <p class="font-body-md text-body-md text-on-surface-variant text-center md:text-left opacity-80 hover:opacity-100 transition-opacity">
      © {currentYear} Raúl Vigil. Portafolio Web.
    </p>
    <div class="flex gap-6">
      <a class="text-on-surface-variant hover:text-primary-fixed transition-colors font-body-md text-body-md" href="https://www.linkedin.com/in/raulvigil/" target="_blank" aria-label="Perfil de LinkedIn de Raúl Vigil">LinkedIn</a>
      <a class="text-on-surface-variant hover:text-primary-fixed transition-colors font-body-md text-body-md" href="https://github.com/RaulVigil" target="_blank" aria-label="Perfil de GitHub de Raúl Vigil">GitHub</a>
      <a class="text-on-surface-variant hover:text-primary-fixed transition-colors font-body-md text-body-md" href="mailto:rauleduardovigil@gmail.com" aria-label="Enviar un correo electrónico a Raúl Vigil">Email</a>
    </div>
  </div>
</footer>
