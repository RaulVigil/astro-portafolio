---
import { siteConfig } from "../data";
---

<footer class="w-full py-stack-md bg-surface-dim border-t border-border-subtle mt-10 relative z-10">
<div class="flex flex-col md:flex-row justify-between items-center px-gutter max-w-container-max mx-auto gap-6">
<div class="text-headline-md font-headline-md text-primary">
                raulo.dev
            </div>
<div class="flex gap-6">
<a aria-label="GitHub" class="text-text-secondary hover:text-surface-tint transition-all opacity-80 hover:opacity-100" href={siteConfig.socials.github} target="_blank">
<span class="material-symbols-outlined text-[24px]">code</span>
</a>
<a aria-label="LinkedIn" class="text-text-secondary hover:text-surface-tint transition-all opacity-80 hover:opacity-100" href={siteConfig.socials.linkedin} target="_blank">
<span class="material-symbols-outlined text-[24px]">work</span>
</a>
<a aria-label="Email" class="text-text-secondary hover:text-surface-tint transition-all opacity-80 hover:opacity-100" href={`mailto:${siteConfig.email}`}>
<span class="material-symbols-outlined text-[24px]">mail</span>
</a>
<a aria-label="WhatsApp" class="text-text-secondary hover:text-surface-tint transition-all opacity-80 hover:opacity-100" href={`https://wa.me/${siteConfig.phone.replace(/[^0-9]/g, '')}`} target="_blank">
<span class="material-symbols-outlined text-[24px]">chat</span>
</a>
</div>
<div class="text-label-sm font-label-sm text-text-secondary">
                © 2026 Raúl Vigil. Built with precision.
            </div>
</div>
</footer>
